# Copy to .env and fill in real values. .env is gitignored — never commit real credentials.

ADMIN_EMAIL=admin@nutribase.test
ADMIN_PASSWORD=changeme

DOCTOR_EMAIL=doctor@nutribase.test
DOCTOR_PASSWORD=changeme

# There's no PATIENT_EMAIL/PASSWORD — the demo creates its own patient account live
# (Doctor segment) and logs into it later (Patient segment); see NEW_PATIENT in steps.ts.

# Optional overrides (defaults shown):
# BASE_URL=http://localhost:3000
# PANEL_PORT=4949
# SLOWMO=150
# DRY_RUN=1
